#!/usr/bin/env bash

set -o pipefail

# shellcheck source=tests/helpers.sh
. "$(dirname "$0")/helpers.sh"

echo "=== session integration ==="

tmp=$(_tmpdir)
mkdir -p "$tmp/home"

file="$tmp/session.lua"
for i in $(seq 1 100); do
  printf 'print("line %s")\n' "$i"
done >"$file"

result=$(_nvim_lua "
  local restore = require('nvim_workspace.session')
  local reopen_events = 0
  vim.api.nvim_create_autocmd('BufReadPost', {
    callback = function(event)
      reopen_events = reopen_events + 1
      local mark = vim.api.nvim_buf_get_mark(event.buf, '\"')
      if mark[1] > 0 then
        pcall(vim.api.nvim_win_set_cursor, 0, mark)
      end
    end,
  })

  vim.cmd('edit ' .. vim.fn.fnameescape('$file'))
  vim.bo.filetype = ''
  vim.api.nvim_buf_set_mark(0, '\"', 7, 0, {})
  vim.api.nvim_win_set_cursor(0, {80, 0})
  reopen_events = 0

  restore.refresh_current_filetype()

  print(vim.fn.line('.'))
  print(vim.bo.filetype)
  print(reopen_events)
")
expected="$(printf '80\nlua\n0')"
_assert_eq "session: filetype refresh keeps session cursor without reopening" \
  "$expected" "$result"

missing_file="$tmp/deleted.lua"
result=$(_nvim_lua "
  local restore = require('nvim_workspace.session')
  restore.load_current({
    load = function()
      vim.cmd('badd ' .. vim.fn.fnameescape('$missing_file'))
      vim.cmd('argadd ' .. vim.fn.fnameescape('$missing_file'))
    end,
  })

  vim.wait(1000, function()
    for _, buf in ipairs(vim.api.nvim_list_bufs()) do
      if vim.api.nvim_buf_get_name(buf) == '$missing_file' then
        return false
      end
    end
    return true
  end)

  local found = false
  for _, buf in ipairs(vim.api.nvim_list_bufs()) do
    if vim.api.nvim_buf_get_name(buf) == '$missing_file' then
      found = true
    end
  end
  print(vim.fn.argc())
  print(tostring(found))
")
expected="$(printf '0\nfalse')"
_assert_eq "session: load_current clears arglist and prunes missing buffers" \
  "$expected" "$result"

save_tmp=$(_tmpdir)
mkdir -p "$save_tmp/home" "$save_tmp/project/src" "$save_tmp/project/.git"
save_file="$save_tmp/project/src/session.lua"
printf '%s\n' 'print("session")' >"$save_file"
project_root=$(_realpath "$save_tmp/project")
home_root=$(_realpath "$save_tmp/home")

result=$(_nvim_lua "
  local restore = require('nvim_workspace.session')
  vim.cmd('cd ' .. vim.fn.fnameescape('$home_root'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$save_file'))

  local saves = {}
  restore.save_current({
    save = function()
      saves[#saves + 1] = vim.fn.getcwd()
    end,
  })

  print(vim.fn.getcwd())
  print(table.concat(saves, '|'))
")
expected="$(printf '%s\n%s|%s' "$home_root" "$home_root" "$project_root")"
_assert_eq "session: saves file project session from different launch cwd" \
  "$expected" "$result"

home_save_tmp=$(_tmpdir)
mkdir -p "$home_save_tmp/home/project/src" "$home_save_tmp/home/project/.git"
home_save_file="$home_save_tmp/home/project/src/session.lua"
printf '%s\n' 'print("home")' >"$home_save_file"
home_save_home=$(_realpath "$home_save_tmp/home")
home_save_project=$(_realpath "$home_save_tmp/home/project")
result=$(_nvim_lua "
  vim.env.HOME = '$home_save_home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local restore = require('nvim_workspace.session')
  vim.cmd('cd ' .. vim.fn.fnameescape('$home_save_project'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$home_save_file'))

  local saves = {}
  restore.save_current({
    save = function()
      saves[#saves + 1] = vim.fn.getcwd()
    end,
  })

  print(vim.fn.getcwd())
  print(table.concat(saves, '|'))
")
expected="$(printf '%s\n%s|%s' "$home_save_project" "$home_save_project" "$home_save_home")"
_assert_eq "session: saves home session for project launch under home" "$expected" "$result"

result=$(_nvim_lua "
  local restore = require('nvim_workspace.session')
  local saves = 0
  package.loaded.persistence = {
    active = function()
      return false
    end,
    save = function()
      saves = saves + 1
    end,
  }

  restore.save()

  print(saves)
")
_assert_eq "session: save interface does not require active session" "1" "$result"

multi_tmp=$(_tmpdir)
mkdir -p "$multi_tmp/home" "$multi_tmp/project-a/src" "$multi_tmp/project-a/.git"
mkdir -p "$multi_tmp/project-b/src" "$multi_tmp/project-b/.git"
printf '%s\n' 'print("a")' >"$multi_tmp/project-a/src/a.lua"
printf '%s\n' 'print("b")' >"$multi_tmp/project-b/src/b.lua"
multi_home=$(_realpath "$multi_tmp/home")
multi_a=$(_realpath "$multi_tmp/project-a")
multi_b=$(_realpath "$multi_tmp/project-b")
result=$(_nvim_lua "
  local restore = require('nvim_workspace.session')
  vim.cmd('cd ' .. vim.fn.fnameescape('$multi_home'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$multi_tmp/project-a/src/a.lua'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$multi_tmp/project-b/src/b.lua'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$multi_tmp/project-a/src/a.lua'))

  local saves = {}
  restore.save_current({
    save = function()
      saves[#saves + 1] = vim.fn.getcwd()
    end,
  })

  print(vim.fn.getcwd())
  print(table.concat(saves, '|'))
")
expected="$(printf '%s\n%s|%s|%s' "$multi_home" "$multi_home" "$multi_a" "$multi_b")"
_assert_eq "session: saves each file project root once" "$expected" "$result"

covered_tmp=$(_tmpdir)
mkdir -p "$covered_tmp/home" "$covered_tmp/project/src" "$covered_tmp/project/lib"
printf '%s\n' 'print("one")' >"$covered_tmp/project/src/one.lua"
printf '%s\n' 'print("two")' >"$covered_tmp/project/lib/two.lua"
covered_home=$(_realpath "$covered_tmp/home")
covered_project=$(_realpath "$covered_tmp/project")

result=$(_nvim_lua "
  package.loaded['nvim_workspace.core.workspace'] = {
    normalize = function(path)
      return vim.fn.fnamemodify(path, ':p'):gsub('/$', '')
    end,
    default_root = function()
      return '$covered_home'
    end,
    find_repo_root = function(dir)
      error('unexpected root detection: ' .. tostring(dir))
    end,
    contains = function(root, path)
      return path == root or path:sub(1, #root + 1) == root .. '/'
    end,
  }

  local restore = require('nvim_workspace.session')
  vim.cmd('cd ' .. vim.fn.fnameescape('$covered_project'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$covered_tmp/project/src/one.lua'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$covered_tmp/project/lib/two.lua'))

  local saves = {}
  restore.save_current({
    save = function()
      saves[#saves + 1] = vim.fn.getcwd()
    end,
  })

  print(table.concat(saves, '|'))
")
_assert_eq "session: launch cwd covers file buffers without root probes" \
  "$covered_project" "$result"

cache_tmp=$(_tmpdir)
mkdir -p "$cache_tmp/home/project/.git" "$cache_tmp/home/project/src" "$cache_tmp/home/project/lib"
printf '%s\n' 'print("one")' >"$cache_tmp/home/project/src/one.lua"
printf '%s\n' 'print("two")' >"$cache_tmp/home/project/lib/two.lua"
cache_home=$(_realpath "$cache_tmp/home")
cache_project=$(_realpath "$cache_tmp/home/project")

result=$(_nvim_lua "
  local root_calls = 0
  package.loaded['nvim_workspace.core.workspace'] = {
    normalize = function(path)
      return vim.fn.fnamemodify(path, ':p'):gsub('/$', '')
    end,
    default_root = function()
      return '$cache_home'
    end,
    find_repo_root = function(dir)
      root_calls = root_calls + 1
      return '$cache_project'
    end,
    contains = function(root, path)
      return path == root or path:sub(1, #root + 1) == root .. '/'
    end,
  }

  local restore = require('nvim_workspace.session')
  vim.cmd('cd ' .. vim.fn.fnameescape('$cache_home'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$cache_tmp/home/project/src/one.lua'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$cache_tmp/home/project/lib/two.lua'))

  local saves = {}
  restore.save_current({
    save = function()
      saves[#saves + 1] = vim.fn.getcwd()
    end,
  })

  print(root_calls)
  print(table.concat(saves, '|'))
")
expected="$(printf '1\n%s|%s' "$cache_home" "$cache_project")"
_assert_eq "session: reuses discovered roots while preserving nested repo probes" \
  "$expected" "$result"

fail_tmp=$(_tmpdir)
mkdir -p "$fail_tmp/home" "$fail_tmp/project/src" "$fail_tmp/project/.git"
printf '%s\n' 'print("fail")' >"$fail_tmp/project/src/fail.lua"
fail_home=$(_realpath "$fail_tmp/home")
fail_project=$(_realpath "$fail_tmp/project")
result=$(_nvim_lua "
  local restore = require('nvim_workspace.session')
  vim.cmd('cd ' .. vim.fn.fnameescape('$fail_home'))
  vim.cmd('edit ' .. vim.fn.fnameescape('$fail_tmp/project/src/fail.lua'))

  local saves = 0
  local ok, err = pcall(function()
    restore.save_current({
      save = function()
        saves = saves + 1
        if saves == 2 then
          error('alias save failed')
        end
      end,
    })
  end)

  print(tostring(ok))
  print(err and err:match('alias save failed') or 'missing-error')
  print(vim.fn.getcwd())
")
expected="$(printf 'false\nalias save failed\n%s' "$fail_home")"
_assert_eq "session: failed alias save restores cwd" "$expected" "$result"
