#!/usr/bin/env bash

set -o pipefail

# shellcheck source=tests/helpers.sh
. "$(dirname "$0")/helpers.sh"

echo "=== lazygit: workspace-aware options ==="

tmp=$(_tmpdir)
home="$tmp/home"
project="$tmp/project"
project_real=$(_realpath "$project")
mkdir -p "$home/.config/nvim" "$project/src" "$project/.git"
touch "$home/.bashrc" "$home/.config/nvim/init.lua" "$home/untracked"
touch "$project/src/main.lua"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  print(tostring(lazygit.opts_for_path('$home/.bashrc')))
")
expected="nil"
_assert_eq "lazygit: generic default has no special repo args" "$expected" "$result"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  require('nvim_workspace').setup({
    lazygit = {
      opts_for_path = function(path, ctx)
        local rel = ctx.relative_to_default_root(path)
        print('path=' .. path)
        print('rel=' .. tostring(rel))
        if rel == '.bashrc' or rel == '.config/nvim/init.lua' then
          return {
            cwd = ctx.default_root,
            args = { '--repo-root', ctx.default_root, '--rel', rel },
          }
        end
      end,
    },
  })
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  local dot_opts = lazygit.opts_for_path('$home/.bashrc')
  print(dot_opts.cwd)
  print(table.concat(dot_opts.args, ' '))
  local opts = lazygit.opts_for_path('$home/.config/nvim/init.lua')
  print(opts.cwd)
  print(table.concat(opts.args, ' '))
  print(tostring(lazygit.opts_for_path('$home/untracked')))
")
expected="$(printf 'path=%s\nrel=.bashrc\n%s\n--repo-root %s --rel .bashrc\npath=%s\nrel=.config/nvim/init.lua\n%s\n--repo-root %s --rel .config/nvim/init.lua\npath=%s\nrel=untracked\nnil' \
  "$home/.bashrc" "$home" "$home" \
  "$home/.config/nvim/init.lua" "$home" "$home" \
  "$home/untracked")"
_assert_eq "lazygit: host callback can return special repo args" \
  "$expected" "$result"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  require('nvim_workspace').setup({
    lazygit = {
      opts_for_path = function()
        error('broken host policy')
      end,
    },
  })
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  print(tostring(lazygit.opts_for_path('$home/.bashrc')))
")
expected="nil"
_assert_eq "lazygit: host callback failures fail closed" "$expected" "$result"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  vim.api.nvim_command('edit $project/src/main.lua')
  print(lazygit.cwd_for_context())
  local opts = lazygit.opts()
  print(opts.cwd)
  print(tostring(opts.args))
")
expected="$(printf '%s\n%s\nnil' "$project_real" "$project_real")"
_assert_eq "lazygit: normal files use the detected VCS root" "$expected" "$result"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  vim.api.nvim_command('cd $project/src')
  vim.api.nvim_command('new')
  vim.bo.buftype = 'nofile'
  local opts = lazygit.opts()
  print(opts.cwd)
  print(tostring(opts.args))
")
expected="$(printf '%s\nnil' "$project_real")"
_assert_eq "lazygit: special buffers fall back to cwd context" "$expected" "$result"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  require('nvim_workspace').setup({
    lazygit = {
      opts_for_path = function(_, ctx)
        return {
          cwd = ctx.default_root,
          args = { '--repo-root', ctx.default_root },
        }
      end,
    },
  })
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  vim.api.nvim_command('edit $home/.bashrc')
  local called = nil
  local snacks = {
    lazygit = function(opts)
      called = opts.cwd .. '|' .. table.concat(opts.args or {}, ' ')
      return 'opened'
    end,
  }
  print(lazygit.open_with_snacks(snacks))
  print(called)
")
expected="$(printf 'opened\n%s|--repo-root %s' "$home" "$home")"
_assert_eq "lazygit: optional Snacks launcher uses computed options" \
  "$expected" "$result"

echo ""
