#!/usr/bin/env bash

set -o pipefail

# shellcheck source=tests/helpers.sh
. "$(dirname "$0")/helpers.sh"

echo "=== lazygit: workspace-aware options ==="

tmp=$(_tmpdir)
home="$tmp/home"
project="$tmp/project"
mkdir -p "$home/.dotfiles" "$home/.config/nvim" "$project/src"
touch "$home/.bashrc" "$home/.config/nvim/init.lua" "$home/untracked"
touch "$project/src/main.lua"
project_real=$(_realpath "$project")

bin=$(_tmpdir)
cat >"$bin/git" <<'EOF'
#!/usr/bin/env sh
if [ "$1" != "--git-dir" ] || [ "$2" != "$HOME/.dotfiles" ]; then
  exit 2
fi
if [ "$3" != "--work-tree" ] || [ "$4" != "$HOME" ]; then
  exit 2
fi
if [ "$5" != "ls-files" ] || [ "$6" != "--error-unmatch" ] || [ "$7" != "--" ]; then
  exit 2
fi
case "$8" in
  .bashrc|.config/nvim/init.lua)
    exit 0
    ;;
esac
exit 1
EOF
chmod +x "$bin/git"

cat >"$bin/sley" <<EOF
#!/usr/bin/env sh
cwd=\$(pwd -P)
case "\$cwd" in
  "$project_real"|"$project_real"/*)
    printf '{"repo_type":"git","root":"%s","ref":"main","counts":{"staged":0,"pending":0,"unstaged":0,"untracked":0},"dirty":false}\n' "$project_real"
    exit 0
    ;;
esac
printf '%s\n' 'sley: unsupported repo' >&2
exit 2
EOF
chmod +x "$bin/sley"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  local dot_opts = lazygit.opts_for_path('$home/.bashrc')
  print(dot_opts.cwd)
  print(table.concat(dot_opts.args, ' '))
  local opts = lazygit.opts_for_path('$home/.config/nvim/init.lua')
  print(opts.cwd)
  print(table.concat(opts.args, ' '))
  print(tostring(lazygit.opts_for_path('$home/untracked')))
")
expected="$(printf '%s\n--work-tree %s --git-dir %s\n%s\n--work-tree %s --git-dir %s\nnil' \
  "$home" "$home" "$home/.dotfiles" "$home" "$home" "$home/.dotfiles")"
_assert_eq "lazygit: detects tracked dotfiles and returns bare repo args" \
  "$expected" "$result"

missing_home="$tmp/missing-home"
mkdir -p "$missing_home"
touch "$missing_home/.bashrc"
result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$missing_home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  print(tostring(lazygit.opts_for_path('$missing_home/.bashrc')))
")
expected="nil"
_assert_eq "lazygit: missing dotfiles repo fails closed" "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  vim.api.nvim_command('edit $project/src/main.lua')
  print(lazygit.cwd_for_context())
  local opts = lazygit.opts()
  print(opts.cwd)
  print(tostring(opts.args))
")
expected="$(printf '%s\n%s\nnil' "$project_real" "$project_real")"
_assert_eq "lazygit: normal files use the detected VCS root" "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  vim.api.nvim_command('cd $project/src')
  vim.api.nvim_command('new')
  vim.bo.buftype = 'nofile'
  local opts = lazygit.opts()
  print(opts.cwd)
  print(tostring(opts.args))
")
expected="$(printf '%s\nnil' "$project_real")"
_assert_eq "lazygit: special buffers fall back to cwd context" "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local lazygit = require('nvim_workspace.lazygit')
  vim.api.nvim_command('edit $home/.bashrc')
  local called = nil
  local snacks = {
    lazygit = function(opts)
      called = opts.cwd .. '|' .. table.concat(opts.args or {}, ' ')
      return 'opened'
    end,
  }
  print(lazygit.open_with_snacks(snacks))
  print(called)
")
expected="$(printf 'opened\n%s|--work-tree %s --git-dir %s' \
  "$home" "$home" "$home/.dotfiles")"
_assert_eq "lazygit: optional Snacks launcher uses computed options" \
  "$expected" "$result"

echo ""
