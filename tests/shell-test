#!/usr/bin/env bash

set -o pipefail

# shellcheck source=tests/helpers.sh
. "$(dirname "$0")/helpers.sh"

echo "=== shell integration ==="

tmp=$(_tmpdir)
home="$tmp/home"
project="$tmp/project"
overlay="$home/.dotfiles-work"
mkdir -p "$home/.dotfiles" "$home/.config/shell/lib" "$home/.local/bin"
mkdir -p "$project/scripts" "$overlay/home/.config/shell/lib"
touch "$home/.bashrc" "$home/.config/shell/lib/common.bash"
touch "$home/.local/bin/agent-hook-test" "$home/.local/bin/plain-tool"
touch "$project/scripts/run.sh" "$overlay/home/.config/shell/lib/overlay.bash"
project_real=$(_realpath "$project")
overlay_real=$(_realpath "$overlay")

bin=$(_tmpdir)
cat >"$bin/sley" <<EOF
#!/usr/bin/env sh
cwd=\$(pwd -P)
if [ "$1" = "status" ] && [ "$2" = "--json" ] && [ "${SLEY_BARE_REPO_GIT_DIR:-}" = "$home/.dotfiles" ]; then
  printf '{"repo_type":"git","root":"%s","ref":"main","counts":{"staged":0,"pending":0,"unstaged":0,"untracked":0},"dirty":false}\n' "$home"
  exit 0
fi
case "\$cwd" in
  "$project_real"|"$project_real"/*)
    printf '{"repo_type":"git","root":"%s","ref":"main","counts":{"staged":0,"pending":0,"unstaged":0,"untracked":0},"dirty":false}\n' "$project_real"
    exit 0
    ;;
  "$overlay_real"|"$overlay_real"/*)
    printf '{"repo_type":"git","root":"%s","ref":"main","counts":{"staged":0,"pending":0,"unstaged":0,"untracked":0},"dirty":false}\n' "$overlay_real"
    exit 0
    ;;
esac
printf '%s\n' 'sley: unsupported repo' >&2
exit 2
EOF
chmod +x "$bin/sley"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local shell = require('nvim_workspace.shell')
  print(shell.root_for('$project/scripts/run.sh'))
  print(shell.glob_for('$project'))
  local paths, globs, root = shell.search_paths_for('$project/scripts/run.sh')
  print(root)
  print(table.concat(paths, ','))
  print(table.concat(globs or {}, ','))
")
expected="$(printf '%s\n**/*@(.sh|.inc|.bash|.zsh|.command)\n%s\n%s\n*.sh,*.inc,*.bash,*.zsh,*.command' \
  "$project_real" "$project_real" "$project_real")"
_assert_eq "shell: normal repos use VCS root and recursive globs" "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  require('nvim_workspace').setup({
    shell = { shell_glob = '*.bash' },
  })
  local shell = require('nvim_workspace.shell')
  print(shell.glob_for('$project'))
")
expected="**/*.bash"
_assert_eq "shell: shell_glob customizes the derived recursive glob" "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local shell = require('nvim_workspace.shell')
  print(shell.root_for('$home/.bashrc'))
  print(shell.glob_for('$home'))
  local paths, globs, root = shell.search_paths_for('$home/.bashrc')
  print(root)
  print(table.concat(paths, ','))
  print(tostring(globs))
  print(tostring(shell.is_home_shell_path('$home/.bashrc')))
  print(tostring(shell.is_home_shell_path('$home/random.sh')))
")
expected="$(printf '%s\n{.bashrc,.bash_profile,.profile,.zshenv,.zprofile,.zshrc}\n%s\n%s\nnil\ntrue\nfalse' \
  "$home" "$home" "$home/.bashrc")"
_assert_eq "shell: default HOME policy is bounded to startup files" "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  require('nvim_workspace').setup({
    shell = {
      home_globs = { '.local/bin/agent-hook-*' },
      home_dirs = {
        { prefix = '.config/shell/', glob = '.config/shell/**/*@(.sh|.bash)' },
        { prefix = '.local/bin/', direct = true },
      },
      overlay = { enabled = true },
    },
  })
  local shell = require('nvim_workspace.shell')
  print(tostring(shell.is_home_shell_path('$home/.local/bin/plain-tool')))
  print(shell.root_for('$home/.local/bin/plain-tool'))
  print(shell.root_for('$home/.local/bin/agent-hook-test'))
  print(shell.root_for('$home/.config/shell/lib/common.bash'))
  print(shell.glob_for('$home'))
  local paths = shell.search_paths_for('$home/.local/bin/agent-hook-test')
  print(table.concat(paths, ','))
")
expected="$(printf 'true\n%s\n%s\n%s\n{.bashrc,.bash_profile,.profile,.zshenv,.zprofile,.zshrc,.local/bin/agent-hook-*,.config/shell/**/*@(.sh|.bash)}\n%s,%s,%s' \
  "$home" "$home" "$home" "$home/.bashrc" "$home/.local/bin/agent-hook-test" "$home/.config/shell")"
_assert_eq "shell: setup recognizes direct HOME paths without scanning all HOME" \
  "$expected" "$result"

result=$(PATH="$bin:$PATH" _nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  require('nvim_workspace').setup({
    shell = {
      home_dirs = {
        { prefix = '.config/shell/', glob = '.config/shell/**/*@(.sh|.bash)' },
      },
      overlay = { enabled = true },
    },
  })
  local shell = require('nvim_workspace.shell')
  print(shell.root_for('$overlay/home/.config/shell/lib/overlay.bash'))
  print(shell.glob_for('$overlay'))
  local paths, globs, root = shell.search_paths_for('$overlay/home/.config/shell/lib/overlay.bash')
  print(root)
  print(table.concat(paths, ','))
  print(tostring(globs))
")
expected="$(printf '%s\n{home/.bashrc,home/.bash_profile,home/.profile,home/.zshenv,home/.zprofile,home/.zshrc,home/.config/shell/**/*@(.sh|.bash)}\n%s\n%s\nnil' \
  "$overlay_real" "$overlay_real" "$overlay_real/home/.config/shell")"
_assert_eq "shell: optional overlays reuse HOME-shaped bounded search policy" \
  "$expected" "$result"

result=$(_nvim_lua "
  local shell = require('nvim_workspace.shell')
  local called = nil
  shell.root_dir(vim.api.nvim_get_current_buf(), function(root)
    called = root
  end)
  print(tostring(called))
  vim.api.nvim_buf_set_name(0, 'term://host/shell')
  shell.root_dir(vim.api.nvim_get_current_buf(), function(root)
    called = root
  end)
  print(tostring(called))
")
expected="$(printf 'nil\nnil')"
_assert_eq "shell: root_dir ignores empty and URI buffers" "$expected" "$result"

result=$(_nvim_lua "
  vim.env.HOME = '$home'
  package.loaded['nvim_workspace.core.workspace'] = nil
  local shell = require('nvim_workspace.shell')
  local config = { root_dir = '$home' }
  shell.before_init(nil, config)
  print(tostring(config.settings.bashIde.includeAllWorkspaceSymbols))
  print(config.settings.bashIde.globPattern)
")
expected="$(printf 'true\n{.bashrc,.bash_profile,.profile,.zshenv,.zprofile,.zshrc}')"
_assert_eq "shell: before_init configures bashls with bounded glob policy" \
  "$expected" "$result"

echo ""
