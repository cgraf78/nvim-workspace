#!/usr/bin/env bash

set -o pipefail

# shellcheck source=tests/helpers.sh
. "$(dirname "$0")/helpers.sh"

echo "=== public api ==="

result=$(_nvim_lua '
  local workspace = require("nvim_workspace")
  print(type(workspace.setup))
  print(type(workspace.files))
  print(type(workspace.grep))
  print(type(workspace.default_root))
  print(type(workspace.normalize))
  print(type(workspace.canonical))
  print(type(workspace.relative_path))
  print(type(workspace.current_file_dir))
  print(type(workspace.current_buffer_dir))
  print(type(workspace.current_file_repo_root))
  print(type(workspace.repo_root))
  print(type(workspace.path_query_terms))
  print(type(workspace.unordered_path_regex))
')
expected="$(printf 'function\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction')"
_assert_eq "api: exposes facade entrypoints without internal module escape hatch" "$expected" "$result"

result=$(_nvim_lua '
  local workspace = require("nvim_workspace")
  print(tostring(workspace.workspace == nil))
')
expected="true"
_assert_eq "api: does not expose internal workspace module through facade" "$expected" "$result"

result=$(_nvim_lua '
  local neo_tree = require("nvim_workspace.neo_tree")
  local session = require("nvim_workspace.session")
  local lazygit = require("nvim_workspace.lazygit")
  local shell = require("nvim_workspace.shell")
  local navigation = require("nvim_workspace.navigation")
  print(type(neo_tree.filesystem_policy))
  print(type(neo_tree.setup_manager_patch))
  print(type(session.setup))
  print(type(session.load))
  print(type(session.save))
  print(type(lazygit.opts))
  print(type(lazygit.opts_for_path))
  print(type(lazygit.cwd_for_context))
  print(type(lazygit.open_with_snacks))
  print(type(shell.root_for))
  print(type(shell.search_paths_for))
  print(type(shell.before_init))
  print(type(navigation["goto"]))
  print(type(navigation.follow))
  print(type(navigation.goto_mouse))
  print(type(navigation.has_lsp_definition))
  print(type(navigation.file_location_at_cursor))
')
expected="$(printf 'function\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction\nfunction')"
_assert_eq "api: exposes optional integration modules explicitly" "$expected" "$result"

result=$(_nvim_lua '
  local saved_uv = vim.uv
  vim.uv = nil
  package.loaded["nvim_workspace.core.uv"] = nil
  local uv = require("nvim_workspace.core.uv")
  print(uv == vim.loop)
  vim.uv = saved_uv
')
_assert_eq "api: uv helper falls back to vim.loop" "true" "$result"

result=$(grep -R -n "vim\\.uv" "$TEST_ROOT/lua" | grep -v "/lua/nvim_workspace/core/uv.lua" || true)
_assert_eq "api: uv access stays behind compatibility helper" "" "$result"

result=$(_nvim_lua '
  local saved_islist = vim.islist
  vim.islist = nil
  package.loaded["nvim_workspace.core.list"] = nil
  local list = require("nvim_workspace.core.list")
  print(list.islist({ "a", "b" }))
  print(list.islist({ key = "value" }))
  print(list.islist("not a table"))
  print(list.islist({ [2] = "gap" }))
  vim.islist = saved_islist
')
expected="$(printf 'true\nfalse\nfalse\nfalse')"
_assert_eq "api: list helper works without vim.islist" "$expected" "$result"

result=$(grep -R -n "vim\\.islist" "$TEST_ROOT/lua" | grep -v "/lua/nvim_workspace/core/list.lua" || true)
_assert_eq "api: islist access stays behind compatibility helper" "" "$result"

result=$(_nvim_lua '
  local saved_get_clients = vim.lsp.get_clients
  local saved_get_active_clients = vim.lsp.get_active_clients
  vim.lsp.get_clients = nil
  vim.lsp.get_active_clients = function(opts)
    print(opts.bufnr)
    return {
      { id = 7 },
    }
  end
  package.loaded["nvim_workspace.core.lsp"] = nil
  local lsp = require("nvim_workspace.core.lsp")
  local clients = lsp.get_clients({ bufnr = 13 })
  print(#clients)
  print(clients[1].id)
  vim.lsp.get_clients = saved_get_clients
  vim.lsp.get_active_clients = saved_get_active_clients
')
expected="$(printf '13\n1\n7')"
_assert_eq "api: lsp helper falls back to get_active_clients" "$expected" "$result"

result=$(grep -R -n "vim\\.lsp\\.get_clients" "$TEST_ROOT/lua" | grep -v "/lua/nvim_workspace/core/lsp.lua" || true)
_assert_eq "api: lsp client lookup stays behind compatibility helper" "" "$result"

result=$(_nvim_lua '
  local workspace = require("nvim_workspace")
  local files_fn = function() end
  local grep_fn = function() end
  workspace.register_file_source(files_fn, { name = "Files index" })
  workspace.register_grep_source(grep_fn, { name = "Grep index" })
  local files = require("nvim_workspace.picker.files")
  local grep = require("nvim_workspace.picker.grep")
  print(files.sources[1].run == files_fn)
  print(files.sources[1].name)
  print(grep.sources[1].run == grep_fn)
  print(grep.sources[1].name)
')
expected="$(printf 'true\nFiles index\ntrue\nGrep index')"
_assert_eq "api: source registration delegates to picker modules" "$expected" "$result"

result=$(_nvim_lua '
  local uv = require("nvim_workspace.core.uv")
  local workspace = require("nvim_workspace")
  local tmp = vim.fn.tempname()
  vim.fn.mkdir(tmp .. "/repo/src", "p")
  local file = tmp .. "/repo/src/example.lua"
  vim.fn.writefile({ "return true" }, file)
  print(workspace.normalize(file) == tmp .. "/repo/src")
  print(workspace.canonical(tmp .. "/repo") == uv.fs_realpath(tmp .. "/repo"))
  print(workspace.relative_path(tmp .. "/repo", file))
  print(table.concat(workspace.path_query_terms("foo bar"), ","))
  print(workspace.unordered_path_regex("foo bar"))
')
expected="$(printf 'true\ntrue\nsrc/example.lua\nfoo,bar\nfoo.*bar|bar.*foo')"
_assert_eq "api: exposes path and query helpers through facade" "$expected" "$result"

result=$(_nvim_lua '
  require("nvim_workspace").setup({
    large_root_detector = function(path, opts)
      print(path)
      print(tostring(opts and opts.search_root))
      return path == "/tmp/large"
    end,
  })
  _G.in_large_repo = function()
    error("global detector should not be used when setup detector exists")
  end
  local workspace = require("nvim_workspace.core.workspace")
  print(tostring(workspace.is_large_repo("/tmp/large", { search_root = true })))
')
expected="$(printf '/tmp/large\ntrue\ntrue')"
_assert_eq "api: setup large_root_detector overrides global detector" "$expected" "$result"

result=$(_nvim_lua '
  local session_opts
  package.loaded["nvim_workspace.session"] = {
    setup = function(opts)
      session_opts = opts
    end,
  }
  require("nvim_workspace").setup({
    session = {
      save_debounce_ms = 123,
    },
  })
  print(session_opts.save_debounce_ms)
')
_assert_eq "api: setup delegates configured session lifecycle" "123" "$result"

result=$(_nvim_lua '
  vim.cmd("runtime plugin/nvim-workspace.lua")
  local commands = vim.api.nvim_get_commands({})
  print(type(commands.WorkspaceFiles))
  print(type(commands.WorkspaceGrep))
')
expected="$(printf 'table\ntable')"
_assert_eq "plugin: registers workspace picker commands lazily" "$expected" "$result"
